        window.copyCombinedPayloads = function () {
            const allPayloads = generatedPayloads.map(e => e.payload);
            const text = JSON.stringify(allPayloads, null, 2);
            navigator.clipboard.writeText(text).then(() => {
                showToast('คัดลอก JSON รวมทั้งหมดสำเร็จ! 📦');
            });
        };

        function copyAllPayloads() {
            const allText = generatedPayloads.map((entry, idx) =>
                `// Payload #${idx + 1}${entry.sheetName ? ' (' + entry.sheetName + ')' : ''}\n${JSON.stringify(entry.payload, null, 2)}`
            ).join('\n\n');
            navigator.clipboard.writeText(allText).then(() => {
                showToast('คัดลอกทั้งหมดสำเร็จ! 🐱');
            });
        }

        async function exportPayloads() {
            try {
                const workbook = new ExcelJS.Workbook();

                generatedPayloads.forEach((entry, pIdx) => {
                    const sheetName = entry.sheetName || `Payload ${pIdx + 1}`;
                    const worksheet = workbook.addWorksheet(sheetName);

                    worksheet.columns = [
                        { header: 'ลำดับ', key: 'no', width: 10 },
                        { header: 'Key', key: 'key', width: 30 },
                        { header: 'Value', key: 'value', width: 40 },
                        { header: 'JSON Payload', key: 'payload', width: 60 }
                    ];

                    worksheet.getRow(1).font = { bold: true, color: { argb: 'FFFFFFFF' } };
                    worksheet.getRow(1).alignment = { vertical: 'middle', horizontal: 'center' };
                    worksheet.getRow(1).fill = { type: 'pattern', pattern: 'solid', fgColor: { argb: 'FFFDA4AF' } };

                    const jsonStr = JSON.stringify(entry.payload, null, 2);
                    entry.items.forEach((item, i) => {
                        const row = worksheet.addRow({
                            no: i + 1,
                            key: item.key,
                            value: item.value,
                            payload: i === 0 ? jsonStr : ''
                        });
                        row.getCell('payload').alignment = { wrapText: true, vertical: 'top' };
                        row.getCell('key').alignment = { vertical: 'top' };
                        row.getCell('value').alignment = { vertical: 'top' };
                        row.getCell('no').alignment = { vertical: 'top' };
                    });
                });

                const buffer = await workbook.xlsx.writeBuffer();
                const blob = new Blob([buffer], { type: 'application/vnd.openxmlformats-officedocument.spreadsheetml.sheet' });
                saveAs(blob, 'Cat_JSON_Payloads.xlsx');
                showToast('ส่งออก Excel สำเร็จ! 📥');
            } catch (error) {
                console.error('Export failed:', error);
                alert('เกิดข้อผิดพลาดในการส่งออกไฟล์: ' + error.message);
            }
        }

        // ==================== AI SIDEBAR LOGIC ====================
        let isAIOpen = false;
        let chatHistory = [];

        window.toggleAI = function () {
            const sidebar = document.getElementById('ai-sidebar');
            const icon = document.getElementById('ai-toggle-icon');
            isAIOpen = !isAIOpen;
            sidebar.style.transform = isAIOpen ? 'translateX(0)' : 'translateX(-100%)';
            icon.textContent = isAIOpen ? '✕' : '🐱';
        };

        let selectedAIFiles = [];

        window.handleAIFileSelect = function (input) {
            const files = Array.from(input.files);
            selectedAIFiles = [...selectedAIFiles, ...files];
            renderAIFilePreviews();
            input.value = '';
        };

        function renderAIFilePreviews() {
            const container = document.getElementById('ai-file-preview');
            if (selectedAIFiles.length === 0) {
                container.classList.add('hidden');
                return;
            }
            container.classList.remove('hidden');
            container.innerHTML = '';
            selectedAIFiles.forEach((file, index) => {
                const item = document.createElement('div');
                item.className = 'file-preview-item';
                item.innerHTML = `
                    <span class="truncate max-w-[150px]">📄 ${file.name}</span>
                    <button onclick="removeAIFile(${index})" class="hover:text-red-600 font-bold">✕</button>
                `;
                container.appendChild(item);
            });
        }

        window.removeAIFile = function (index) {
            selectedAIFiles.splice(index, 1);
            renderAIFilePreviews();
        };

        // Initialize drag & drop for AI sidebar
        setTimeout(() => {
            const chatContainer = document.getElementById('chat-container');
            if (!chatContainer) return;
            chatContainer.addEventListener('dragover', (e) => {
                e.preventDefault();
                chatContainer.classList.add('drag-over');
            });
            ['dragleave', 'drop'].forEach(evt => {
                chatContainer.addEventListener(evt, () => chatContainer.classList.remove('drag-over'));
            });
            chatContainer.addEventListener('drop', (e) => {
                e.preventDefault();
                const files = Array.from(e.dataTransfer.files);
                selectedAIFiles = [...selectedAIFiles, ...files];
                renderAIFilePreviews();
                showToast('เพิ่มไฟล์แล้วแง้ว! 🐾');
            });
        }, 1000);

        window.sendMessage = async function () {
            const input = document.getElementById('chat-input');
            const msg = input.value.trim();
            if (!msg && selectedAIFiles.length === 0) return;

            // Show what's being sent
            let displayMsg = msg;
            if (selectedAIFiles.length > 0) {
                displayMsg = (msg ? msg + '\n' : '') + selectedAIFiles.map(f => '📎 ' + f.name).join('\n');
            }
            addChatMessage('user', displayMsg);
            input.value = '';
            input.style.height = 'auto';

            const formData = new FormData();
            formData.append('message', msg || "ช่วยวิเคราะห์ไฟล์นี้หน่อยครับ");
            formData.append('history', JSON.stringify(chatHistory));
            selectedAIFiles.forEach(file => formData.append('files', file));

            // Clear preview
            selectedAIFiles = [];
            renderAIFilePreviews();

            // Show typing indicator
            const typingId = addChatMessage('ai', '<span class="typing-dot"></span><span class="typing-dot" style="animation-delay: 0.2s"></span><span class="typing-dot" style="animation-delay: 0.4s"></span>', true);

            try {
                const res = await fetch('/api/chat', {
                    method: 'POST',
                    body: formData // No Content-Type header needed for FormData
                });
                const data = await res.json();

                // Remove typing indicator
                document.getElementById(typingId).remove();

                if (data.error) {
                    addChatMessage('ai', '❌ ' + data.error);
                } else {
                    const executeAction = (actionObj) => {
                        if (!actionObj || !actionObj.action) return;
                        switch (actionObj.action) {
                            case 'add_testcases':
                                if (actionObj.data) {
                                    testCases = [...testCases, ...actionObj.data];
                                    renderTable();
                                    showToast('คุมะเพิ่ม Test Case ให้แล้วครับ! 🐾');
                                }
                                break;
                            case 'delete_testcases':
                                if (actionObj.data && Array.isArray(actionObj.data)) {
                                    // Sort indices descending to avoid shifting issues
                                    const sortedIndices = [...actionObj.data]
                                        .map(i => parseInt(i) - 1)
                                        .filter(i => i >= 0 && i < testCases.length)
                                        .sort((a, b) => b - a);

                                    sortedIndices.forEach(idx => {
                                        testCases.splice(idx, 1);
                                    });
                                    renderTable();
                                    showToast(`คุมะลบข้อที่เลือกให้แล้วครับ ${actionObj.data.join(', ')}! 🐾`);
                                }
                                break;
                            case 'edit_testcases':
                                if (actionObj.data && Array.isArray(actionObj.data)) {
                                    let editCount = 0;
                                    actionObj.data.forEach(edit => {
                                        const idx = parseInt(edit.index) - 1; // 1-based → 0-based
                                        if (idx >= 0 && idx < testCases.length) {
                                            if (edit.name !== undefined) testCases[idx].name = edit.name;
                                            if (edit.step !== undefined) testCases[idx].step = edit.step;
                                            if (edit.expected !== undefined) testCases[idx].expected = edit.expected;
                                            editCount++;
                                        }
                                    });
                                    renderTable();
                                    showToast(`คุมะแก้ไข Test Case ${editCount} รายการให้แล้วครับ! ✏️🐾`);
                                }
                                break;
                            case 'switch_page':
                                if (actionObj.page) {
                                    switchPage(actionObj.page);
                                    showToast(`คุมะเปลี่ยนหน้าไปหน้า ${actionObj.page} ให้แล้วครับ! 🐻`);
                                }
                                break;
                            case 'export_excel':
                                const pageToExport = document.getElementById('page1').classList.contains('hidden') ? (document.getElementById('page2').classList.contains('hidden') ? 3 : 2) : 1;
                                if (pageToExport === 1) {
                                    if (testCases.length > 0) document.getElementById('exportBtn').click();
                                    else showToast('ยังไม่มีข้อมูล Test Case ให้ส่งออกครับ 😿', 'error');
                                } else if (pageToExport === 2) {
                                    if (generatedPayloads.length > 0) document.getElementById('exportPayloadBtn').click();
                                    else showToast('ยังไม่มีข้อมูล Payload ให้ส่งออกครับ 😿', 'error');
                                } else {
                                    exportMatrixExcel();
                                }
                                break;
                            case 'save_history':
                                const activeSavePage = document.getElementById('page1').classList.contains('hidden') ? (document.getElementById('page2').classList.contains('hidden') ? 3 : 2) : 1;
                                if (activeSavePage === 1) {
                                    saveTestCaseHistory();
                                } else if (activeSavePage === 2) {
                                    showToast('หน้านี้บันทึกประวัติอัติโนมัติเมื่ออัปโหลดครับเมี้ยว 🐾');
                                } else {
                                    saveMatrixHistory();
                                }
                                break;
                            case 'clear_all':
                                const activeClearPage = document.getElementById('page1').classList.contains('hidden') ? (document.getElementById('page2').classList.contains('hidden') ? 3 : 2) : 1;
                                if (activeClearPage === 1) {
                                    testCases = []; renderTable();
                                } else if (activeClearPage === 2) {
                                    generatedPayloads = []; renderPayloads();
                                } else {
                                    resetMatrix(true);
                                }
                                showToast('คุมะล้างข้อมูลให้เกลี้ยงเลยครับ! 🧼');
                                break;
                            case 'add_payloads':
                                if (actionObj.data) {
                                    const payloads = Array.isArray(actionObj.data) ? actionObj.data : [actionObj.data];
                                    payloads.forEach(p => {
                                        const entry = {
                                            sheetName: p.sheetName || 'AI Generated',
                                            items: p.items || [],
                                            payload: {}
                                        };
                                        function parsePath(path) {
                                            const parts = [];
                                            const tokens = path.replace(/\[(\d+)\]/g, '.$1').split('.');
                                            tokens.forEach(t => { if (/^\d+$/.test(t)) parts.push(parseInt(t, 10)); else parts.push(t); });
                                            return parts;
                                        }
                                        function setNestedValue(obj, path, value) {
                                            const parts = parsePath(path);
                                            let current = obj;
                                            for (let i = 0; i < parts.length - 1; i++) {
                                                const key = parts[i];
                                                if (current[key] === undefined) current[key] = typeof parts[i + 1] === 'number' ? [] : {};
                                                current = current[key];
                                            }
                                            current[parts[parts.length - 1]] = value;
                                        }
                                        entry.items.forEach(item => setNestedValue(entry.payload, item.key, item.value));
                                        generatedPayloads.push(entry);
                                    });
                                    renderPayloads();
                                    saveToHistory('AI_Generated_Payloads', generatedPayloads);
                                    showToast('คุมะสร้าง JSON Payload ให้แล้วครับ! 🔧');
                                }
                                break;
                            case 'copy_text':
                                if (actionObj.data) {
                                    navigator.clipboard.writeText(actionObj.data).then(() => {
                                        showToast('คุมะคัดลอกข้อความเป็น Clipboard ให้แล้วครับ! 📋');
                                    });
                                }
                                break;
                            case 'load_history':
                                if (typeof actionObj.data === 'number') {
                                    const currentPage = document.getElementById('page1').classList.contains('hidden') ? (document.getElementById('page2').classList.contains('hidden') ? 3 : 2) : 1;
                                    if (currentPage === 1) {
                                        const history = JSON.parse(localStorage.getItem(TESTCASE_HISTORY_KEY) || '[]');
                                        if (history[actionObj.data]) {
                                            testCases = [...history[actionObj.data].data];
                                            renderTable();
                                            showToast('คุมะดึงประวัติ Test Case มาให้แล้วครับ! 📂');
                                        }
                                    } else if (currentPage === 2) {
                                        const history = JSON.parse(localStorage.getItem(HISTORY_KEY) || '[]');
                                        if (history[actionObj.data]) {
                                            generatedPayloads = [...history[actionObj.data].payloads];
                                            renderPayloads();
                                            showToast('คุมะดึงประวัติ Payload มาให้แล้วครับ! 📂');
                                        }
                                    } else {
                                        const history = JSON.parse(localStorage.getItem(MATRIX_HISTORY_KEY) || '[]');
                                        if (history[actionObj.data]) {
                                            matrixRequirements = [...history[actionObj.data].requirements];
                                            matrixTestCases = [...history[actionObj.data].testcases];
                                            matrixMapping = JSON.parse(JSON.stringify(history[actionObj.data].mapping));
                                            renderMatrix();
                                            showToast('คุมะดึงประวัติ Matrix มาให้แล้วครับ! 📂');
                                        }
                                    }
                                }
                                break;
                            case 'update_matrix':
                                if (actionObj.data) {
                                    matrixRequirements = actionObj.data.requirements || [];
                                    matrixTestCases = actionObj.data.testcases || [];
                                    matrixMapping = actionObj.data.mapping || {};
                                    switchPage(3);
                                    renderMatrix();
                                    showToast('คุมะสร้าง Test Coverage Matrix ให้แล้วครับ! 📊🐾');
                                }
                                break;
                        }
                    };

                    if (data.actions && Array.isArray(data.actions)) {
                        data.actions.forEach(act => {
                            executeAction(act);
                        });
                    } else if (data.action) {
                        executeAction(data);
                    }
                    if (data.message) addChatMessage('ai', data.message);

                    // Update internal chat history
                    chatHistory.push({ role: 'user', parts: [{ text: msg }] });
                    chatHistory.push({ role: 'model', parts: [{ text: data.message || '' }] });
                }
            } catch (err) {
                console.error('Chat error detail:', err);
                document.getElementById(typingId).remove();
                addChatMessage('ai', 'ขออภัยครับแม่มนุษย์ คุมะมีปัญหาขัดข้อง... 😿 (รายละเอียด: ' + err.message + ')');
            }
        };

        function addChatMessage(role, text, isRaw = false) {
            const container = document.getElementById('chat-container');
            const id = 'chat-' + Date.now();
            const div = document.createElement('div');
            div.id = id;
            div.className = `chat-bubble ${role} shadow-sm fade-in`;
            if (isRaw) div.innerHTML = text;
            else div.textContent = text;
            container.appendChild(div);
            container.scrollTop = container.scrollHeight;
            return id;
        }

        const chatInput = document.getElementById('chat-input');
        if (chatInput) {
            chatInput.addEventListener('input', function () {
                this.style.height = 'auto';
                this.style.height = (this.scrollHeight) + 'px';
            });

            chatInput.addEventListener('keydown', (e) => {
                if (e.key === 'Enter' && !e.shiftKey) {
                    e.preventDefault();
                    sendMessage();
                }
            });
        }

        // ==================== INLINE EDITING LOGIC ====================
        window.updateTestCaseData = function (index, field, value) {
            testCases[index][field] = value.trim();
        };

        // Modify renderTable to add contenteditable
        function renderTable() {
            tableBody.innerHTML = '';
            const copySheetsBtn = document.getElementById('copySheetsBtn');
            if (testCases.length === 0) {
                emptyState.classList.remove('hidden');
                exportBtn.classList.add('hidden');
                if (copySheetsBtn) copySheetsBtn.classList.add('hidden');
            } else {
                emptyState.classList.add('hidden');
                exportBtn.classList.remove('hidden');
                if (copySheetsBtn) copySheetsBtn.classList.remove('hidden');
                testCases.forEach((tc, index) => {
                    const row = document.createElement('tr');
                    row.className = 'border-b border-rose-50 hover:bg-rose-50/30 transition-colors';
                    row.innerHTML = `
                        <td class="py-4 px-4 font-medium">${index + 1}</td>
                        <td class="py-4 px-4" contenteditable="true" onblur="updateTestCaseData(${index}, 'name', this.innerText)">${escapeHtml(tc.name)}</td>
                        <td class="py-4 px-4 whitespace-pre-line" contenteditable="true" onblur="updateTestCaseData(${index}, 'step', this.innerText)">${escapeHtml(tc.step)}</td>
                        <td class="py-4 px-4 whitespace-pre-line" contenteditable="true" onblur="updateTestCaseData(${index}, 'expected', this.innerText)">${escapeHtml(tc.expected)}</td>
                        <td class="py-4 px-4 text-center">
                            <button onclick="deleteStep(${index})" class="btn-danger w-8 h-8 rounded-full inline-flex items-center justify-center font-bold" title="ลบขั้นตอน">✕</button>
                        </td>
                    `;
                    tableBody.appendChild(row);
                });
            }
        }

        // ==================== PAGE 1 HISTORY LOGIC ====================
        const TESTCASE_HISTORY_KEY = 'cat_testcase_history';

        window.saveTestCaseHistory = function () {
            if (testCases.length === 0) {
                alert('โปรดเพิ่ม Test Case ก่อนบันทึกนะแง้ว!');
                return;
            }
            const name = prompt('กรุณาตั้งชื่อชุด Test Case นี้:', testCases[0].name || 'ชุดทดสอบใหม่');
            if (name === null) return;

            const history = JSON.parse(localStorage.getItem(TESTCASE_HISTORY_KEY) || '[]');
            history.unshift({
                id: Date.now(),
                name: name || 'ไม่ได้ระบุชื่อ',
                date: new Date().toLocaleString('th-TH'),
                data: [...testCases]
            });
            localStorage.setItem(TESTCASE_HISTORY_KEY, JSON.stringify(history));
            renderTestCaseHistory();
            showToast('บันทึกประวัติสำเร็จ! 💾');
        };

        function renderTestCaseHistory() {
            const list = document.getElementById('testCaseHistoryList');
            const empty = document.getElementById('testCaseHistoryEmpty');
            const history = JSON.parse(localStorage.getItem(TESTCASE_HISTORY_KEY) || '[]');

            list.innerHTML = '';
            if (history.length === 0) {
                empty.classList.remove('hidden');
                return;
            }
            empty.classList.add('hidden');

            history.forEach((item, idx) => {
                const el = document.createElement('div');
                el.className = 'flex items-center justify-between bg-white border-2 border-rose-50 rounded-xl px-4 py-3 hover:border-rose-200 transition-all shadow-sm';
                el.innerHTML = `
                    <div class="flex items-center gap-3">
                        <span class="text-xl">📋</span>
                        <div>
                            <p class="font-bold text-gray-700 text-sm">${escapeHtml(item.name)}</p>
                            <p class="text-xs text-gray-400">${item.date} · ${item.data.length} ขั้นตอน</p>
                        </div>
                    </div>
                    <div class="flex gap-2">
                        <button onclick="loadTestCaseFromHistory(${idx})" class="bg-rose-50 text-rose-500 px-3 py-1 rounded-lg text-xs font-bold hover:bg-rose-100 transition-colors">
                            📂 ดึงข้อมูล
                        </button>
                        <button onclick="deleteTestCaseHistory(${idx})" class="text-gray-300 hover:text-red-400 p-1 transition-colors">
                            ✕
                        </button>
                    </div>
                `;
                list.appendChild(el);
            });
        }

        window.loadTestCaseFromHistory = function (idx) {
            const history = JSON.parse(localStorage.getItem(TESTCASE_HISTORY_KEY) || '[]');
            if (confirm('ต้องการดึงข้อมูลชุดนี้มาแทนที่ข้อมูลปัจจุบันใช่หรือไม่?')) {
                testCases = [...history[idx].data];
                renderTable();
                showToast('ดึงข้อมูลสำเร็จ! 🐾');
            }
        };

        window.deleteTestCaseHistory = function (idx) {
            if (!confirm('ยืนยันระบบลบบันทึกชุดนี้?')) return;
            const history = JSON.parse(localStorage.getItem(TESTCASE_HISTORY_KEY) || '[]');
            history.splice(idx, 1);
            localStorage.setItem(TESTCASE_HISTORY_KEY, JSON.stringify(history));
            renderTestCaseHistory();
        };

        renderTestCaseHistory();

        // Toast notification
        function showToast(message) {
            const toast = document.createElement('div');
            toast.className = 'fixed bottom-6 right-6 bg-gray-800 text-white px-6 py-3 rounded-xl shadow-2xl text-sm font-medium z-50 fade-in';
            toast.textContent = message;
            document.body.appendChild(toast);
            setTimeout(() => toast.remove(), 2500);
        }

        // ==================== PAGE 3: Test Coverage Matrix Logic ====================
        let matrixRequirements = [];
        let matrixTestCases = [];
        let matrixMapping = {}; // key: reqIdx (string), value: array of tcIdx (numbers)
        const MATRIX_HISTORY_KEY = 'cat_matrix_history';

        window.addRequirement = function () {
            const input = document.getElementById('reqInput');
            const val = input.value.trim();
            if (!val) return;
            matrixRequirements.push(val);
            input.value = '';
            renderMatrix();
            input.focus();
        };

        window.addMatrixTestCase = function () {
            const input = document.getElementById('matrixTcInput');
            const val = input.value.trim();
            if (!val) return;
            matrixTestCases.push(val);
            input.value = '';
            renderMatrix();
            input.focus();
        };

        window.pullTestCasesFromPage1 = function () {
            if (testCases.length === 0) {
                showToast('ไม่พบ Test Case ในหน้าแรกครับเมี้ยว 😿');
                return;
            }
            const tcNames = testCases.map(tc => tc.name).filter((val, idx, self) => val && self.indexOf(val) === idx);
            if (tcNames.length === 0) {
                showToast('ไม่พบชื่อ Test Case ที่สมบูรณ์ในหน้าแรก 😿');
                return;
            }
            if (matrixTestCases.length > 0 && !confirm('ต้องการดึงกรณีทดสอบมาเขียนทับรายการเดิมทั้งหมดใช่หรือไม่?\n(กดยกเลิกเพื่อเพิ่มต่อท้าย)')) {
                // Add unique only
                tcNames.forEach(name => {
                    if (!matrixTestCases.includes(name)) {
                        matrixTestCases.push(name);
                    }
                });
            } else {
                matrixTestCases = tcNames;
                matrixMapping = {};
            }
            renderMatrix();
            showToast('ดึงกรณีทดสอบจากหน้าแรกสำเร็จ! 🐾');
        };

        window.toggleMatrixMapping = function (reqIdx, tcIdx) {
            if (!matrixMapping[reqIdx]) {
                matrixMapping[reqIdx] = [];
            }
            const idx = matrixMapping[reqIdx].indexOf(tcIdx);
            if (idx > -1) {
                matrixMapping[reqIdx].splice(idx, 1);
            } else {
                matrixMapping[reqIdx].push(tcIdx);
            }
            renderMatrix();
        };

        window.updateRequirementText = function (reqIdx, text) {
            if (text.trim() === '') {
                deleteRequirement(reqIdx);
            } else {
                matrixRequirements[reqIdx] = text.trim();
                updateMatrixStats();
            }
        };

        window.updateMatrixTestCaseName = function (tcIdx, text) {
            if (text.trim() === '') {
                deleteMatrixTestCase(tcIdx);
            } else {
                matrixTestCases[tcIdx] = text.trim();
                updateMatrixStats();
            }
        };

        window.deleteRequirement = function (reqIdx) {
            matrixRequirements.splice(reqIdx, 1);
            
            // Adjust mapping keys
            const newMapping = {};
            for (const key in matrixMapping) {
                const kNum = parseInt(key);
                if (kNum === reqIdx) continue;
                if (kNum > reqIdx) {
                    newMapping[String(kNum - 1)] = matrixMapping[key];
                } else {
                    newMapping[key] = matrixMapping[key];
                }
            }
            matrixMapping = newMapping;
            renderMatrix();
        };

        window.deleteMatrixTestCase = function (tcIdx) {
            matrixTestCases.splice(tcIdx, 1);
            
            // Adjust mapping values
            for (const key in matrixMapping) {
                matrixMapping[key] = matrixMapping[key]
                    .filter(val => val !== tcIdx)
                    .map(val => val > tcIdx ? val - 1 : val);
            }
            renderMatrix();
        };

        window.updateMatrixStats = function () {
            const statTotalReqs = document.getElementById('statTotalReqs');
            const statTotalTcs = document.getElementById('statTotalTcs');
            const statCoveragePct = document.getElementById('statCoveragePct');
            
            if (!statTotalReqs || !statTotalTcs || !statCoveragePct) return;
            
            const totalReqs = matrixRequirements.length;
            const totalTcs = matrixTestCases.length;
            
            statTotalReqs.textContent = totalReqs;
            statTotalTcs.textContent = totalTcs;
            
            if (totalReqs === 0) {
                statCoveragePct.textContent = '0%';
                return;
            }
            
            let coveredReqsCount = 0;
            for (let i = 0; i < totalReqs; i++) {
                if (matrixMapping[i] && matrixMapping[i].length > 0) {
                    coveredReqsCount++;
                }
            }
            
            const pct = Math.round((coveredReqsCount / totalReqs) * 100);
            statCoveragePct.textContent = `${pct}%`;
        };

        window.resetMatrix = function (skipConfirm = false) {
            if (!skipConfirm && !confirm('คุณต้องการล้างข้อมูลความครอบคลุมทั้งหมดใช่หรือไม่?')) return;
            matrixRequirements = [];
            matrixTestCases = [];
            matrixMapping = {};
            renderMatrix();
            if (!skipConfirm) showToast('ล้างตารางเมทริกซ์สำเร็จ! 🧼');
        };

        window.requestAIAutoMap = function () {
            if (matrixRequirements.length === 0 || matrixTestCases.length === 0) {
                alert('โปรดเพิ่ม Test Scenario และเงื่อนไขก่อนขอให้คุมะวิเคราะห์จับคู่นะแง้ว!');
                return;
            }
            
            const messageText = `ช่วยวิเคราะห์เงื่อนไข (เงื่อนไข) และ Test Scenario ต่อไปนี้ แล้วส่ง JSON action "update_matrix" เพื่อจับคู่ความครอบคลุม (Test Coverage Mapping) ให้หน่อยครับเมี้ยว:
            
เงื่อนไข (Column):
${matrixRequirements.map((r, i) => `${i + 1}. ${r}`).join('\n')}

Test Scenario (Row):
${matrixTestCases.map((tc, i) => `${i + 1}. ${tc}`).join('\n')}`;

            if (!isAIOpen) {
                toggleAI();
            }
            
            const chatInput = document.getElementById('chat-input');
            chatInput.value = messageText;
            sendMessage();
        };

        window.copyForGoogleSheets = function () {
            if (matrixTestCases.length === 0) {
                alert('ยังไม่มีข้อมูล Test Scenario ในการคัดลอกครับ 😿');
                return;
            }
            
            let tsv = '';
            
            // Header Row
            const headers = ['ลำดับ', 'Test Scenario'];
            matrixRequirements.forEach(req => {
                headers.push(req);
            });
            tsv += headers.join('\t') + '\n';
            
            // Data Rows
            matrixTestCases.forEach((tc, tIdx) => {
                const row = [tIdx + 1, tc];
                matrixRequirements.forEach((req, rIdx) => {
                    const isMapped = matrixMapping[rIdx] && matrixMapping[rIdx].includes(tIdx);
                    row.push(isMapped ? '✔️' : '');
                });
                tsv += row.join('\t') + '\n';
            });
            
            // Add coverage footer row
            const footRow = ['ความครอบคลุม (เงื่อนไข)', ''];
            matrixRequirements.forEach((req, rIdx) => {
                const hasCover = matrixMapping[rIdx] && matrixMapping[rIdx].length > 0;
                footRow.push(hasCover ? 'ครอบคลุม' : 'ไม่ครอบคลุม');
            });
            tsv += footRow.join('\t') + '\n';
            
            navigator.clipboard.writeText(tsv).then(() => {
                showToast('คัดลอกเมทริกซ์ในรูปแบบ Google Sheets สำเร็จ! วาง (Ctrl+V) ได้เลยครับ 🟢🐾');
            }).catch(err => {
                console.error('TSV copy failed:', err);
                alert('ไม่สามารถคัดลอกได้: ' + err.message);
            });
        };

        async function exportMatrixExcel() {
            if (matrixTestCases.length === 0) {
                alert('ยังไม่มีข้อมูล Test Scenario ในการส่งออกครับ 😿');
                return;
            }
            try {
                const workbook = new ExcelJS.Workbook();
                const worksheet = workbook.addWorksheet('Test Coverage Matrix');
                
                const cols = [
                    { header: 'ลำดับ', key: 'no', width: 8 },
                    { header: 'Test Scenario', key: 'tc', width: 35 }
                ];
                matrixRequirements.forEach((req, idx) => {
                    cols.push({ header: req, key: `req_${idx}`, width: 15 });
                });
                worksheet.columns = cols;
                
                const headerRow = worksheet.getRow(1);
                headerRow.font = { bold: true, color: { argb: 'FFFFFFFF' } };
                headerRow.alignment = { vertical: 'middle', horizontal: 'center', wrapText: true };
                
                headerRow.eachCell((cell) => {
                    cell.fill = {
                        type: 'pattern',
                        pattern: 'solid',
                        fgColor: { argb: 'FFFDA4AF' }
                    };
                });
                
                matrixTestCases.forEach((tc, tIdx) => {
                    const rowData = { no: tIdx + 1, tc: tc };
                    matrixRequirements.forEach((req, rIdx) => {
                        const isMapped = matrixMapping[rIdx] && matrixMapping[rIdx].includes(tIdx);
                        rowData[`req_${rIdx}`] = isMapped ? '✔️' : '';
                    });
                    
                    const row = worksheet.addRow(rowData);
                    row.alignment = { vertical: 'middle' };
                    
                    row.getCell('no').alignment = { vertical: 'middle', horizontal: 'center' };
                    row.getCell('tc').alignment = { vertical: 'middle', horizontal: 'left', wrapText: true };
                    
                    matrixRequirements.forEach((req, rIdx) => {
                        const cell = row.getCell(`req_${rIdx}`);
                        cell.alignment = { vertical: 'middle', horizontal: 'center' };
                        if (cell.value === '✔️') {
                            cell.font = { bold: true, color: { argb: 'FF059669' } };
                            cell.fill = {
                                type: 'pattern',
                                pattern: 'solid',
                                fgColor: { argb: 'FFD1FAE5' }
                            };
                        }
                    });
                });
                
                // Add footer row in Excel
                const footRowData = { no: 'ความครอบคลุม (เงื่อนไข)', tc: '' };
                matrixRequirements.forEach((req, rIdx) => {
                    const hasCover = matrixMapping[rIdx] && matrixMapping[rIdx].length > 0;
                    footRowData[`req_${rIdx}`] = hasCover ? 'ครอบคลุม' : 'ไม่ครอบคลุม';
                });
                const footRow = worksheet.addRow(footRowData);
                footRow.alignment = { vertical: 'middle' };
                const tcCell = footRow.getCell('no');
                tcCell.font = { bold: true, color: { argb: 'FFBE185D' } }; // rose-700
                tcCell.fill = {
                    type: 'pattern',
                    pattern: 'solid',
                    fgColor: { argb: 'FFFDF2F8' } // rose-50
                };
                
                const tcDescCell = footRow.getCell('tc');
                tcDescCell.fill = {
                    type: 'pattern',
                    pattern: 'solid',
                    fgColor: { argb: 'FFFDF2F8' }
                };
                
                matrixRequirements.forEach((req, rIdx) => {
                    const cell = footRow.getCell(`req_${rIdx}`);
                    cell.alignment = { vertical: 'middle', horizontal: 'center' };
                    cell.font = { bold: true };
                    const hasCover = matrixMapping[rIdx] && matrixMapping[rIdx].length > 0;
                    if (hasCover) {
                        cell.font = { bold: true, color: { argb: 'FF059669' } };
                        cell.fill = {
                            type: 'pattern',
                            pattern: 'solid',
                            fgColor: { argb: 'FFD1FAE5' }
                        };
                    } else {
                        cell.font = { bold: true, color: { argb: 'FFDC2626' } };
                        cell.fill = {
                            type: 'pattern',
                            pattern: 'solid',
                            fgColor: { argb: 'FFFEE2E2' }
                        };
                    }
                });
                
                for (let r = 1; r <= worksheet.rowCount; r++) {
                    const row = worksheet.getRow(r);
                    for (let c = 1; c <= cols.length; c++) {
                        const cell = row.getCell(c);
                        cell.border = {
                            top: { style: 'thin', color: { argb: 'FFE2E8F0' } },
                            left: { style: 'thin', color: { argb: 'FFE2E8F0' } },
                            bottom: { style: 'thin', color: { argb: 'FFE2E8F0' } },
                            right: { style: 'thin', color: { argb: 'FFE2E8F0' } }
                        };
                    }
                }
                
                const buffer = await workbook.xlsx.writeBuffer();
                const blob = new Blob([buffer], { type: 'application/vnd.openxmlformats-officedocument.spreadsheetml.sheet' });
                saveAs(blob, 'Cat_Test_Coverage_Matrix.xlsx');
                showToast('ส่งออก Excel Test Coverage Matrix สำเร็จ! 📊📥');
            } catch (error) {
                console.error('Matrix export failed:', error);
                alert('เกิดข้อผิดพลาดในการส่งออกไฟล์ Matrix: ' + error.message);
            }
        }

        window.renderMatrix = function () {
            const header = document.getElementById('matrixHeader');
            const body = document.getElementById('matrixBody');
            const emptyState = document.getElementById('matrixEmptyState');
            
            if (!header || !body || !emptyState) return;
            
            header.innerHTML = '';
            body.innerHTML = '';
            
            if (matrixRequirements.length === 0 && matrixTestCases.length === 0) {
                emptyState.classList.remove('hidden');
                updateMatrixStats();
                return;
            }
            emptyState.classList.add('hidden');
            
            const hr = document.createElement('tr');
            hr.className = 'border-b-2 border-rose-50 bg-rose-50/20';
            
            const thNo = document.createElement('th');
            thNo.className = 'py-3 px-4 text-rose-500 font-semibold text-sm w-16 text-center';
            thNo.textContent = 'ลำดับ';
            hr.appendChild(thNo);

            const thReq = document.createElement('th');
            thReq.className = 'py-3 px-4 text-rose-500 font-semibold text-sm w-1/3 border-l border-rose-50/50';
            thReq.textContent = 'Test Scenario';
            hr.appendChild(thReq);
            
            matrixRequirements.forEach((req, idx) => {
                const th = document.createElement('th');
                th.className = 'py-3 px-4 text-rose-400 font-semibold text-sm text-center border-l border-rose-50/50 min-w-[120px] relative group';
                
                const titleSpan = document.createElement('span');
                titleSpan.contentEditable = true;
                titleSpan.className = 'outline-none focus:bg-white focus:border focus:border-rose-300 px-1 rounded block';
                titleSpan.textContent = req;
                titleSpan.onblur = function() {
                    updateRequirementText(idx, this.innerText);
                };
                
                const delBtn = document.createElement('button');
                delBtn.className = 'absolute -top-1 -right-1 bg-red-100 text-red-500 rounded-full w-4 h-4 text-[9px] font-bold items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity';
                delBtn.textContent = '✕';
                delBtn.onclick = function(e) {
                    e.stopPropagation();
                    deleteRequirement(idx);
                };
                
                const wrapDiv = document.createElement('div');
                wrapDiv.className = 'relative inline-block pr-3 w-full';
                wrapDiv.appendChild(titleSpan);
                wrapDiv.appendChild(delBtn);
                
                th.appendChild(wrapDiv);
                hr.appendChild(th);
            });
            
            const thAct = document.createElement('th');
            thAct.className = 'py-3 px-4 text-rose-500 font-semibold text-sm text-center border-l border-rose-50/50 w-16';
            thAct.textContent = 'จัดการ';
            hr.appendChild(thAct);
            
            header.appendChild(hr);
            
            matrixTestCases.forEach((tc, tIdx) => {
                const tr = document.createElement('tr');
                tr.className = 'border-b border-rose-50 hover:bg-rose-50/30 transition-colors';
                
                const tdNo = document.createElement('td');
                tdNo.className = 'py-3 px-4 font-medium text-gray-400 text-sm text-center w-16';
                tdNo.textContent = tIdx + 1;
                tr.appendChild(tdNo);

                const tdReq = document.createElement('td');
                tdReq.className = 'py-3 px-4 font-medium text-gray-700 text-sm border-l border-rose-50/50';
                tdReq.contentEditable = true;
                tdReq.textContent = tc;
                tdReq.onblur = function() {
                    updateMatrixTestCaseName(tIdx, this.innerText);
                };
                tr.appendChild(tdReq);
                
                matrixRequirements.forEach((req, rIdx) => {
                    const td = document.createElement('td');
                    td.className = 'py-3 px-4 text-center border-l border-rose-50/50 cursor-pointer select-none text-xl hover:bg-rose-100/30 transition-colors';
                    
                    const isMapped = matrixMapping[rIdx] && matrixMapping[rIdx].includes(tIdx);
                    if (isMapped) {
                        td.textContent = '🐾';
                        td.className += ' text-rose-400 bg-rose-50/20';
                    }
                    
                    td.onclick = function() {
                        toggleMatrixMapping(rIdx, tIdx);
                    };
                    tr.appendChild(td);
                });
                
                const tdAct = document.createElement('td');
                tdAct.className = 'py-3 px-4 text-center border-l border-rose-50/50';
                tdAct.innerHTML = `
                    <button onclick="deleteMatrixTestCase(${tIdx})" class="btn-danger w-6 h-6 rounded-full inline-flex items-center justify-center font-bold text-xs" title="ลบ Test Scenario">✕</button>
                `;
                tr.appendChild(tdAct);
                
                body.appendChild(tr);
            });
            
            if (matrixTestCases.length > 0 && matrixRequirements.length > 0) {
                const trFoot = document.createElement('tr');
                trFoot.className = 'bg-rose-50/10 font-bold border-t-2 border-rose-50';
                
                const tdLabel = document.createElement('td');
                tdLabel.className = 'py-3 px-4 text-rose-500 text-sm';
                tdLabel.colSpan = 2;
                tdLabel.textContent = 'ความครอบคลุม (เงื่อนไข)';
                trFoot.appendChild(tdLabel);
                
                matrixRequirements.forEach((req, rIdx) => {
                    const td = document.createElement('td');
                    td.className = 'py-3 px-4 text-center border-l border-rose-50/50 text-xs';
                    const hasCover = matrixMapping[rIdx] && matrixMapping[rIdx].length > 0;
                    if (hasCover) {
                        td.innerHTML = '<span class="text-green-500 bg-green-50 px-2 py-1 rounded-full">ครอบคลุม ✔️</span>';
                    } else {
                        td.innerHTML = '<span class="text-rose-400 bg-rose-50 px-2 py-1 rounded-full">ไม่ครอบคลุม ✕</span>';
                    }
                    trFoot.appendChild(td);
                });
                
                const tdActEmpty = document.createElement('td');
                tdActEmpty.className = 'py-3 px-4 border-l border-rose-50/50';
                trFoot.appendChild(tdActEmpty);
                
                body.appendChild(trFoot);
            }
            
            updateMatrixStats();
        };

        window.saveMatrixHistory = function () {
            if (matrixRequirements.length === 0 && matrixTestCases.length === 0) {
                alert('โปรดระบุข้อมูล Matrix ก่อนบันทึกนะแง้ว!');
                return;
            }
            const name = prompt('กรุณาตั้งชื่อชุด Test Coverage Matrix นี้:', matrixRequirements[0] ? `เมทริกซ์สำหรับ ${matrixRequirements[0]}` : 'เมทริกซ์ใหม่');
            if (name === null) return;
            
            const history = JSON.parse(localStorage.getItem(MATRIX_HISTORY_KEY) || '[]');
            history.unshift({
                id: Date.now(),
                name: name || 'ไม่ได้ระบุชื่อ',
                date: new Date().toLocaleString('th-TH'),
                requirements: [...matrixRequirements],
                testcases: [...matrixTestCases],
                mapping: JSON.parse(JSON.stringify(matrixMapping))
            });
            localStorage.setItem(MATRIX_HISTORY_KEY, JSON.stringify(history));
            renderMatrixHistory();
            showToast('บันทึกประวัติเมทริกซ์สำเร็จ! 💾');
        };

        function renderMatrixHistory() {
            const list = document.getElementById('matrixHistoryList');
            const empty = document.getElementById('matrixHistoryEmpty');
            if (!list || !empty) return;
            const history = JSON.parse(localStorage.getItem(MATRIX_HISTORY_KEY) || '[]');
            
            list.innerHTML = '';
            if (history.length === 0) {
                empty.classList.remove('hidden');
                return;
            }
            empty.classList.add('hidden');
            
            history.forEach((item, idx) => {
                const el = document.createElement('div');
                el.className = 'flex items-center justify-between bg-white border-2 border-rose-50 rounded-xl px-4 py-3 hover:border-rose-200 transition-all shadow-sm';
                el.innerHTML = `
                    <div class="flex items-center gap-3">
                        <span class="text-xl">📊</span>
                        <div>
                            <p class="font-bold text-gray-700 text-sm">${escapeHtml(item.name)}</p>
                            <p class="text-xs text-gray-400">${item.date} · ${item.requirements.length} เงื่อนไข · ${item.testcases.length} Scenario</p>
                        </div>
                    </div>
                    <div class="flex gap-2">
                        <button onclick="loadMatrixFromHistory(${idx})" class="bg-rose-50 text-rose-500 px-3 py-1 rounded-lg text-xs font-bold hover:bg-rose-100 transition-colors">
                            📂 ดึงข้อมูล
                        </button>
                        <button onclick="deleteMatrixHistory(${idx})" class="text-gray-300 hover:text-red-400 p-1 transition-colors">
                            ✕
                        </button>
                    </div>
                `;
                list.appendChild(el);
            });
        }

        window.loadMatrixFromHistory = function (idx) {
            const history = JSON.parse(localStorage.getItem(MATRIX_HISTORY_KEY) || '[]');
            if (confirm('ต้องการดึงข้อมูลชุดนี้มาแทนที่ข้อมูลปัจจุบันใช่หรือไม่?')) {
                matrixRequirements = [...history[idx].requirements];
                matrixTestCases = [...history[idx].testcases];
                matrixMapping = JSON.parse(JSON.stringify(history[idx].mapping));
                renderMatrix();
                showToast('ดึงข้อมูลเมทริกซ์สำเร็จ! 🐾');
            }
        };

        window.deleteMatrixHistory = function (idx) {
            if (!confirm('ยืนยันระบบลบบันทึกเมทริกซ์ชุดนี้?')) return;
            const history = JSON.parse(localStorage.getItem(MATRIX_HISTORY_KEY) || '[]');
            history.splice(idx, 1);
            localStorage.setItem(MATRIX_HISTORY_KEY, JSON.stringify(history));
            renderMatrixHistory();
            showToast('ลบประวัติแล้ว');
        };
        
        setTimeout(() => {
            const reqInput = document.getElementById('reqInput');
            const matrixTcInput = document.getElementById('matrixTcInput');
            if (reqInput) {
                reqInput.addEventListener('keydown', (e) => {
                    if (e.key === 'Enter') addRequirement();
                });
            }
            if (matrixTcInput) {
                matrixTcInput.addEventListener('keydown', (e) => {
                    if (e.key === 'Enter') addMatrixTestCase();
                });
            }
            renderMatrixHistory();
            renderMatrix();
        }, 500);
    </script>

