    <script>
        (function () {
            const pet = document.getElementById('kuma-pet');
            const houseBtn = document.getElementById('cat-house-btn');
            const bubble = pet.querySelector('.kuma-bubble');
            let catOut = false;
            let isDragging = false;
            let walkInterval = null;
            let idleTimeout = null;
            let sleepTimeout = null;
            let bubbleTimeout = null;
            let happyTimeout = null;
            let dragMoved = false;
            let posX = 100, posY = 60;
            let dirX = 1; // 1 = right, -1 = left
            let speed = 1.5;
            let dragOffsetX = 0, dragOffsetY = 0;

            function sayBubble(text, duration = 3000) {
                if (bubbleTimeout) clearTimeout(bubbleTimeout);
                bubble.textContent = text;
                pet.classList.add('saying');
                
                bubbleTimeout = setTimeout(() => {
                    pet.classList.remove('saying');
                }, duration);
            }

            function createFloatingEmoji(emoji) {
                const el = document.createElement('span');
                el.textContent = emoji;
                el.style.position = 'absolute';
                el.style.top = '-10px';
                el.style.left = '50%';
                el.style.transform = 'translateX(-50%)';
                el.style.fontSize = '18px';
                el.style.pointerEvents = 'none';
                el.style.zIndex = '9999';
                el.style.transition = 'all 1s ease-out';
                pet.appendChild(el);
                
                setTimeout(() => {
                    el.style.transform = 'translate(-50%, -45px) scale(1.4)';
                    el.style.opacity = '0';
                }, 50);
                
                setTimeout(() => {
                    el.remove();
                }, 1000);
            }

            window.petCat = function () {
                if (isDragging) return;
                
                // Wake up if sleeping
                if (pet.classList.contains('sleeping')) {
                    pet.classList.remove('sleeping');
                    startWalking();
                    sayBubble('ฮ้าววว~ ตื่นแล้วครับคุณแม่มนุษย์! 🥱🐾');
                    return;
                }
                
                // Stop walking briefly
                stopWalking();
                pet.classList.remove('walking');
                pet.classList.add('happy');
                
                const quotes = [
                    'เหมียว~ 🐾',
                    'คุมะรักคุณแม่มนุษย์นะเหมียว~ ❤️',
                    'วันนี้ทำเก่งมากเลยครับ! 💻',
                    'คุมะสแตนด์บายตรวจเทสอยู่ครับ! 🔎🐾',
                    'เกาพุงคุมะอีกๆ เมี้ยว~ 🥰',
                    'มีอะไรให้คุมะช่วยเขียนเทสบอกได้เลยครับแง้ว! 🦊'
                ];
                const randQuote = quotes[Math.floor(Math.random() * quotes.length)];
                sayBubble(randQuote);
                
                if (happyTimeout) clearTimeout(happyTimeout);
                happyTimeout = setTimeout(() => {
                    pet.classList.remove('happy');
                    if (catOut && !isDragging) startWalking();
                }, 1500);
            };

            // Toggle cat house
            window.toggleCatHouse = function () {
                if (catOut) {
                    // Send cat home
                    catOut = false;
                    stopWalking();
                    pet.classList.remove('walking', 'sleeping', 'entering');
                    pet.classList.add('hidden-cat');
                    houseBtn.innerHTML = '🏠<span class="tooltip">เรียกคุมะออกมาเล่น!</span>';
                } else {
                    // Let cat out
                    catOut = true;
                    pet.classList.remove('hidden-cat');
                    pet.classList.add('entering');
                    pet.style.left = posX + 'px';
                    pet.style.bottom = posY + 'px';
                    houseBtn.innerHTML = '🏠<span class="tooltip">ให้คุมะเข้าบ้าน</span>';
                    setTimeout(() => {
                        pet.classList.remove('entering');
                        startWalking();
                    }, 700);
                }
            };

            function startWalking() {
                if (walkInterval) clearInterval(walkInterval);
                pet.classList.remove('sleeping');
                pet.classList.add('walking');
                resetIdleTimer();

                walkInterval = setInterval(() => {
                    if (isDragging || !catOut) return;

                    posX += dirX * speed;

                    // Bounce off viewport edges
                    const maxX = window.innerWidth - 80;
                    if (posX <= 10) { posX = 10; dirX = 1; }
                    if (posX >= maxX) { posX = maxX; dirX = -1; }

                    pet.style.left = posX + 'px';
                    const wrapper = pet.querySelector('.kuma-wrapper');
                    if (wrapper) wrapper.style.transform = dirX < 0 ? 'scaleX(1)' : 'scaleX(-1)';
                }, 30);

                // Randomly change direction
                scheduleDirectionChange();
            }

            function scheduleDirectionChange() {
                const next = 2000 + Math.random() * 5000;
                setTimeout(() => {
                    if (!catOut || isDragging) return;
                    // Randomly: change direction, pause, or keep going
                    const action = Math.random();
                    if (action < 0.3) {
                        dirX *= -1; // flip
                    } else if (action < 0.5) {
                        // Pause briefly
                        stopWalking();
                        pet.classList.remove('walking');
                        setTimeout(() => {
                            if (catOut && !isDragging) startWalking();
                        }, 1500 + Math.random() * 2000);
                        return;
                    }
                    if (catOut) scheduleDirectionChange();
                }, next);
            }

            function stopWalking() {
                if (walkInterval) { clearInterval(walkInterval); walkInterval = null; }
            }

            function showRandomMascotState() {
                if (!catOut || isDragging || pet.classList.contains('sleeping') || pet.classList.contains('happy')) return;
                const idleQuotes = [
                    'ฮึบๆ เดินออกกำลังกายซะหน่อย 🐾',
                    'คุมะพร้อมตรวจงานแล้วครับ! 🔎',
                    'แอบมองคุณแม่มนุษย์อยู่นะแง้ว~ 👀',
                    'สู้ๆ นะครับ! คุมะเป็นกำลังใจให้ 💖',
                    'คัดลอกตารางไปวางใน Google Sheets ได้เลยนะเหมียว! 🟢'
                ];
                const randQuote = idleQuotes[Math.floor(Math.random() * idleQuotes.length)];
                sayBubble(randQuote, 2500);
            }

            function resetIdleTimer() {
                if (idleTimeout) clearTimeout(idleTimeout);
                if (sleepTimeout) clearTimeout(sleepTimeout);
                pet.classList.remove('sleeping');

                // Periodically show thoughts when walking
                idleTimeout = setInterval(() => {
                    if (Math.random() < 0.4) {
                        showRandomMascotState();
                    }
                }, 12000);

                sleepTimeout = setTimeout(() => {
                    if (!isDragging && catOut) {
                        stopWalking();
                        if (idleTimeout) clearInterval(idleTimeout);
                        pet.classList.remove('walking');
                        pet.classList.add('sleeping');
                        sayBubble('ฟี้... ครอก... 😴', 4000);
                    }
                }, 20000 + Math.random() * 10000);
            }

            // ---- Drag & Drop ----
            function startDrag(e) {
                if (!catOut) return;
                isDragging = true;
                dragMoved = false;
                pet.classList.add('dragging');
                pet.classList.remove('walking', 'sleeping');
                stopWalking();

                const clientX = e.touches ? e.touches[0].clientX : e.clientX;
                const clientY = e.touches ? e.touches[0].clientY : e.clientY;
                const rect = pet.getBoundingClientRect();
                dragOffsetX = clientX - rect.left;
                dragOffsetY = clientY - rect.top;

                e.preventDefault();
            }

            function moveDrag(e) {
                if (!isDragging) return;
                dragMoved = true;
                const clientX = e.touches ? e.touches[0].clientX : e.clientX;
                const clientY = e.touches ? e.touches[0].clientY : e.clientY;

                posX = clientX - dragOffsetX;
                posY = window.innerHeight - clientY - (55 - dragOffsetY);

                // Clamp
                posX = Math.max(0, Math.min(window.innerWidth - 80, posX));
                posY = Math.max(0, Math.min(window.innerHeight - 80, posY));

                pet.style.left = posX + 'px';
                pet.style.bottom = posY + 'px';
                e.preventDefault();
            }

            function endDrag() {
                if (!isDragging) return;
                isDragging = false;
                pet.classList.remove('dragging');
                setTimeout(() => {
                    if (catOut) startWalking();
                }, 500);
            }

            pet.addEventListener('mousedown', startDrag);
            document.addEventListener('mousemove', moveDrag);
            document.addEventListener('mouseup', endDrag);
            pet.addEventListener('touchstart', startDrag, { passive: false });
            document.addEventListener('touchmove', moveDrag, { passive: false });
            document.addEventListener('touchend', endDrag);

            pet.addEventListener('click', () => {
                if (dragMoved) return;
                petCat();
            });

            pet.addEventListener('dblclick', () => {
                if (isDragging) return;
                
                stopWalking();
                pet.classList.remove('walking', 'sleeping');
                pet.classList.add('happy');
                
                const fishQuotes = [
                    'ง่ำๆๆๆ! อร่อยสุดยอดเลยเหมียว! 🐟❤️',
                    'ปลาทูตัวนี้หวานเจี๊ยบ! ขอบคุณนะเหมี้ยว~ 🥰',
                    'งับ! คุมะอิ่มแปร้ พร้อมรันเทสแล้วครับ! ⚡',
                    'แง๊ววว~ ของโปรดคุมะเลย! 😻🐾'
                ];
                const randQuote = fishQuotes[Math.floor(Math.random() * fishQuotes.length)];
                sayBubble(randQuote);
                
                createFloatingEmoji('🐟');
                setTimeout(() => createFloatingEmoji('❤️'), 300);
                
                if (happyTimeout) clearTimeout(happyTimeout);
                happyTimeout = setTimeout(() => {
                    pet.classList.remove('happy');
                    if (catOut && !isDragging) startWalking();
                }, 2000);
            });
        })();
    </script>

    <!-- Visitor Counter Widget -->
    <div class="fixed bottom-4 right-4 bg-white/80 backdrop-blur-md border border-rose-100 rounded-2xl px-4 py-3 shadow-lg z-50 text-xs font-semibold text-gray-600 flex items-center gap-3 transition-transform hover:scale-105 duration-200">
        <div class="flex items-center justify-center w-8 h-8 rounded-full bg-rose-50 text-rose-500 text-lg">
            🐾
        </div>
        <div class="grid grid-cols-3 gap-x-4 divide-x divide-rose-100/50">
            <div class="pl-0">
                <span class="block text-[10px] text-gray-400 uppercase tracking-wider">ทั้งหมด</span>
                <span id="visitor-total" class="text-rose-500 font-bold text-sm">0</span>
            </div>
            <div class="pl-4">
                <span class="block text-[10px] text-gray-400 uppercase tracking-wider">วันนี้</span>
                <span id="visitor-today" class="text-rose-600 font-bold text-sm">0</span>
            </div>
            <div class="pl-4">
                <span class="block text-[10px] text-gray-400 uppercase tracking-wider">ขณะนี้</span>
                <span id="visitor-active" class="text-green-500 font-bold text-sm">0</span>
            </div>
        </div>
    </div>

    <script>
        // ==================== Visitor Statistics Heartbeat ====================
        (function() {
            let visitorId = sessionStorage.getItem('kuma_visitor_id');
            let isNewSession = false;
            
            if (!visitorId) {
                visitorId = 'visitor_' + Date.now() + '_' + Math.random().toString(36).substr(2, 9);
                sessionStorage.setItem('kuma_visitor_id', visitorId);
                isNewSession = true;
            }
            
            async function sendHeartbeat() {
                try {
                    const res = await fetch('/api/visitor-heartbeat', {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json'
                        },
                        body: JSON.stringify({ visitorId, isNewSession })
                    });
                    
                    isNewSession = false;
                    
                    const data = await res.json();
                    if (data.total !== undefined) {
                        document.getElementById('visitor-total').textContent = data.total;
                        document.getElementById('visitor-today').textContent = data.today;
                        document.getElementById('visitor-active').textContent = data.active;
                    }
                } catch (err) {
                    console.error('Visitor heartbeat failed:', err);
                }
            }
            
            sendHeartbeat();
            setInterval(sendHeartbeat, 20000);
        })();
    </script>
</body>

