                date: new Date().toLocaleString('th-TH'),
                payloadCount: payloads.length,
                payloads: payloads
            });
            // Keep max 20 entries
            if (history.length > 20) history.length = 20;
            localStorage.setItem(HISTORY_KEY, JSON.stringify(history));
            renderHistory();
        }

