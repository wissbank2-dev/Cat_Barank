    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image">
    <meta property="twitter:url" content="https://cat-barank.onrender.com/">
    <meta property="twitter:title" content="KUMA Test Case Builder - ผู้ช่วยสร้างกรณีทดสอบ AI">
    <meta property="twitter:description" content="สร้าง Test Case และ JSON Payload ง่ายๆ ด้วยพลัง AI น้องคุมะ">

    <link rel="canonical" href="https://cat-barank.onrender.com/" />
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://cdn.jsdelivr.net/npm/exceljs@4.4.0/dist/exceljs.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/file-saver@2.0.5/dist/FileSaver.min.js"></script>
    <link href="https://fonts.googleapis.com/css2?family=Kanit:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>
        body {
            font-family: 'Kanit', sans-serif;
            background-color: #fff1f2;
        }

        .cat-card {
            background-color: white;
            border: 4px solid #fda4af;
            border-radius: 2.5rem;
        }

        .btn-primary {
            background-color: #fda4af;
            color: white;
            transition: all 0.3s ease;
        }

        .btn-primary:hover:not(:disabled) {
            background-color: #f43f5e;
            transform: translateY(-2px);
        }

        .btn-primary:disabled {
            background-color: #fecdd3;
            cursor: not-allowed;
        }

        .btn-danger {
            background-color: #fee2e2;
            color: #ef4444;
            transition: all 0.2s ease;
        }

        .btn-danger:hover {
            background-color: #fecaca;
        }

        input,
        textarea {
            border: 2px solid #fecdd3;
            border-radius: 1rem;
            transition: border-color 0.3s ease;
        }

        input:focus,
        textarea:focus {
            outline: none;
            border-color: #fda4af;
            box-shadow: 0 0 0 3px rgba(253, 164, 175, 0.2);
        }

        .tab-active {
            background-color: #fda4af;
            color: white;
            box-shadow: 0 4px 15px rgba(253, 164, 175, 0.4);
        }

        .tab-inactive {
            background-color: white;
            color: #fda4af;
            border: 2px solid #fecdd3;
        }

        .tab-inactive:hover {
            background-color: #fff1f2;
        }

        .json-block {
            background-color: #1e293b;
            color: #e2e8f0;
            border-radius: 1rem;
            font-family: 'Courier New', monospace;
            font-size: 0.85rem;
            overflow-x: auto;
        }

        .json-key {
            color: #7dd3fc;
        }

        .json-string {
            color: #86efac;
        }

        .json-number {
            color: #fcd34d;
        }

        .json-bool {
            color: #c4b5fd;
        }

        .upload-zone {
            border: 3px dashed #fecdd3;
            border-radius: 1.5rem;
            transition: all 0.3s ease;
        }

        .upload-zone:hover,
        .upload-zone.drag-over {
            border-color: #fda4af;
            background-color: #fff1f2;
        }

        /* Animated Background Cats */
        #cat-atmosphere {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            z-index: -1;
            pointer-events: none;
            overflow: hidden;
        }

        .bg-cat {
            position: absolute;
            opacity: 0.15;
            filter: grayscale(0.2);
            animation: float 20s infinite linear;
            user-select: none;
        }

        @keyframes float {
            0% {
                transform: translate(0, 0) rotate(0deg);
            }

            25% {
                transform: translate(15px, 25px) rotate(10deg);
            }

            50% {
                transform: translate(-10px, 40px) rotate(-5deg);
            }

            75% {
                transform: translate(-25px, 15px) rotate(5deg);
            }

            100% {
                transform: translate(0, 0) rotate(0deg);
            }
        }

        @keyframes fadeIn {
            from {
                opacity: 0;
                transform: translateY(10px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        /* AI Sidebar Styles */
        #ai-sidebar {
            transition: transform 0.3s ease;
            z-index: 100;
        }

        .chat-bubble {
            border-radius: 1.5rem;
            padding: 0.75rem 1rem;
            max-width: 85%;
            margin-bottom: 0.5rem;
            font-size: 0.9rem;
            line-height: 1.4;
        }

        .chat-bubble.user {
            background-color: #fda4af;
            color: white;
            border-bottom-right-radius: 0.25rem;
            margin-left: auto;
        }

        .chat-bubble.ai {
            background-color: white;
            color: #4b5563;
            border: 2px solid #fecdd3;
            border-bottom-left-radius: 0.25rem;
            margin-right: auto;
        }

        .typing-dot {
            width: 6px;
            height: 6px;
            background: #fda4af;
            border-radius: 50%;
            display: inline-block;
            animation: typing 1s infinite alternate;
        }

        @keyframes typing {
            from {
                opacity: 0.3;
                transform: translateY(0);
            }

            to {
                opacity: 1;
                transform: translateY(-4px);
            }
        }

        /* Editable Table Styles */
        [contenteditable="true"] {
            border-bottom: 1px dashed transparent;
            padding: 2px 4px;
            border-radius: 4px;
            transition: all 0.2s;
        }

        [contenteditable="true"]:hover {
            background-color: #fff1f2;
            border-bottom-color: #fda4af;
        }

        [contenteditable="true"]:focus {
            outline: none;
            background-color: white;
            border: 2px solid #fda4af;
            box-shadow: 0 0 0 3px rgba(253, 164, 175, 0.2);
        }

        .file-preview-item {
            background: white;
            border: 1px solid #fecdd3;
            border-radius: 0.75rem;
            padding: 0.25rem 0.5rem;
            display: flex;
            align-items: center;
            gap: 0.5rem;
            font-size: 0.75rem;
            color: #e11d48;
            box-shadow: 0 1px 2px rgba(0, 0, 0, 0.05);
        }

        .drag-over {
            background-color: #fff1f2 !important;
            border: 4px dashed #fda4af !important;
        }

        #chat-input {
            resize: none;
            max-height: 150px;
            min-height: 42px;
            overflow-y: hidden;
            line-height: 1.5;
        }

        /* ===== KUMA Desktop Pet ===== */
        #kuma-pet {
            position: fixed;
            bottom: 60px;
            left: 100px;
            z-index: 999;
            cursor: grab;
            user-select: none;
            transition: bottom 0.3s ease;
            filter: drop-shadow(2px 4px 6px rgba(0, 0, 0, 0.15));
        }

        #kuma-pet.dragging {
            cursor: grabbing;
            transition: none;
        }

        #kuma-pet.hidden-cat {
            bottom: -120px !important;
            opacity: 0;
            pointer-events: none;
            transition: all 0.5s ease;
        }

        #kuma-pet.entering {
            animation: catEnter 0.6s ease forwards;
        }

        @keyframes catEnter {
            0% {
                bottom: -120px;
                opacity: 0;
            }

            60% {
                bottom: 70px;
                opacity: 1;
            }

            80% {
                bottom: 55px;
            }

            100% {
                bottom: 60px;
                opacity: 1;
            }
        }

        /* Cat Body - Pure CSS Orange Cat */
        .kuma-body {
            position: relative;
            width: 70px;
            height: 55px;
        }

        /* Main body */
        .kuma-body .body {
            position: absolute;
            bottom: 0;
            left: 10px;
            width: 50px;
            height: 35px;
            background: #F4A236;
            border-radius: 50% 50% 45% 45%;
        }

        .kuma-body .body::after {
            content: '';
            position: absolute;
            top: 6px;
            left: 8px;
            width: 34px;
            height: 18px;
            background: #F7C16B;
            border-radius: 50%;
        }

        /* Head */
        .kuma-body .head {
            position: absolute;
            bottom: 22px;
            left: 0;
            width: 34px;
            height: 30px;
            background: #F4A236;
            border-radius: 50% 50% 40% 40%;
            z-index: 2;
        }

        /* Eyes */
        .kuma-body .eye {
            position: absolute;
            width: 6px;
            height: 7px;
            background: #333;
            border-radius: 50%;
            top: 12px;
            z-index: 3;
        }

        .kuma-body .eye.left {
            left: 8px;
        }

        .kuma-body .eye.right {
            left: 20px;
        }

        .kuma-body .eye::after {
            content: '';
            position: absolute;
            width: 2px;
            height: 2px;
            background: white;
            border-radius: 50%;
            top: 1px;
            left: 1px;
        }

        /* Nose */
        .kuma-body .nose {
            position: absolute;
            width: 5px;
            height: 3px;
            background: #E8836B;
            border-radius: 50%;
            top: 17px;
            left: 14px;
            z-index: 3;
        }

        /* Ears */
        .kuma-body .ear {
            position: absolute;
            width: 0;
            height: 0;
            border-left: 7px solid transparent;
            border-right: 7px solid transparent;
            border-bottom: 14px solid #F4A236;
            z-index: 1;
        }

        .kuma-body .ear.left {
            top: -6px;
            left: 1px;
            transform: rotate(-15deg);
        }

        .kuma-body .ear.right {
            top: -6px;
            left: 18px;
            transform: rotate(15deg);
        }

        .kuma-body .ear::after {
            content: '';
            position: absolute;
            border-left: 4px solid transparent;
            border-right: 4px solid transparent;
            border-bottom: 9px solid #FFD4A8;
            top: 4px;
            left: -4px;
        }

        /* Tail */
        .kuma-body .tail {
            position: absolute;
            bottom: 15px;
            right: -5px;
            width: 25px;
            height: 8px;
            background: #F4A236;
            border-radius: 0 50% 50% 0;
            transform-origin: left center;
            animation: tailWag 0.8s ease-in-out infinite alternate;
        }

        @keyframes tailWag {
            from {
                transform: rotate(-10deg);
            }

            to {
                transform: rotate(20deg);
            }
        }

        /* Legs */
        .kuma-body .leg {
            position: absolute;
            bottom: -8px;
            width: 8px;
            height: 12px;
            background: #E8952F;
            border-radius: 0 0 3px 3px;
        }

        .kuma-body .leg.fl {
            left: 14px;
        }

        .kuma-body .leg.fr {
            left: 24px;
        }

        .kuma-body .leg.bl {
            left: 38px;
        }

        .kuma-body .leg.br {
            left: 48px;
        }

        /* Walking animation */
        #kuma-pet.walking .leg.fl,
        #kuma-pet.walking .leg.br {
            animation: legWalk 0.3s ease-in-out infinite alternate;
        }

        #kuma-pet.walking .leg.fr,
        #kuma-pet.walking .leg.bl {
            animation: legWalk 0.3s ease-in-out infinite alternate-reverse;
        }

        @keyframes legWalk {
            from {
                height: 12px;
                bottom: -8px;
            }

            to {
                height: 8px;
                bottom: -4px;
            }
        }

        /* Sleeping animation */
        #kuma-pet.sleeping .eye {
            height: 2px !important;
            top: 15px !important;
            border-radius: 2px !important;
        }

        #kuma-pet.sleeping .zzz {
            display: block;
        }

        .zzz {
            display: none;
            position: absolute;
            top: -15px;
            right: 5px;
            font-size: 12px;
            color: #fda4af;
            animation: zzzFloat 1.5s ease-in-out infinite;
        }

        @keyframes zzzFloat {
            0% {
                opacity: 0;
                transform: translateY(0) scale(0.8);
            }

            50% {
                opacity: 1;
                transform: translateY(-8px) scale(1);
            }

            100% {
                opacity: 0;
                transform: translateY(-16px) scale(0.6);
            }
        }

        /* Rosy cheeks and mouth */
        .kuma-body .blush {
            position: absolute;
            width: 5px;
            height: 3px;
            background: rgba(244, 63, 94, 0.4); /* rose-500 pink blush */
            border-radius: 50%;
            top: 17px;
            z-index: 3;
        }
        .kuma-body .blush.left {
            left: 5px;
        }
        .kuma-body .blush.right {
            left: 24px;
        }
        
        .kuma-body .mouth {
            position: absolute;
            width: 6px;
            height: 4px;
            border: 1.5px solid #c2410c;
            border-top: none;
            border-radius: 0 0 3px 3px;
            top: 18px;
            left: 14px;
            z-index: 3;
        }

        /* Dizzy eyes when dragging */
        #kuma-pet.dragging .eye {
            height: 5px !important;
            width: 5px !important;
            border-radius: 50% !important;
            background: transparent !important;
            border: 1.5px solid #333 !important;
        }
        
        /* Happy state closed eyes */
        #kuma-pet.happy .eye {
            height: 3px !important;
            border-radius: 3px 3px 0 0 !important;
            background: transparent !important;
            border: 1.5px solid #333 !important;
            border-bottom: none !important;
            top: 14px !important;
        }

        /* Happy bounce animation on body */
        #kuma-pet.happy .kuma-body {
            animation: happyBounce 0.5s ease-in-out 2;
        }
        
        @keyframes happyBounce {
            0%, 100% { transform: translateY(0) scaleY(1); }
            50% { transform: translateY(-12px) scaleY(0.9) scaleX(1.05); }
        }

        /* Speech bubble */
        .kuma-bubble {
            position: absolute;
            top: -45px;
            left: 50%;
            transform: translateX(-50%);
            background: white;
            color: #db2777; /* pink-600 */
            border: 2px solid #fecdd3; /* rose-200 */
            padding: 4px 10px;
            border-radius: 12px;
            font-size: 11px;
            font-weight: 600;
            white-space: nowrap;
            box-shadow: 0 4px 8px rgba(0, 0, 0, 0.08);
            opacity: 0;
            pointer-events: none;
            transition: all 0.3s ease;
            z-index: 9999;
        }
        .kuma-bubble::after {
            content: '';
            position: absolute;
            bottom: -6px;
            left: 50%;
            transform: translateX(-50%);
            border-width: 6px 6px 0;
            border-style: solid;
            border-color: white transparent;
            display: block;
            width: 0;
        }
        .kuma-bubble::before {
            content: '';
            position: absolute;
            bottom: -8px;
            left: 50%;
            transform: translateX(-50%);
            border-width: 8px 8px 0;
            border-style: solid;
            border-color: #fecdd3 transparent;
            display: block;
            width: 0;
            z-index: -1;
        }
        #kuma-pet.saying .kuma-bubble {
            opacity: 1;
            transform: translateX(-50%) translateY(-5px);
        }

        /* Cat House Button */
        #cat-house-btn {
            position: fixed;
            top: 15px;
            right: 15px;
            z-index: 1000;
            width: 48px;
            height: 48px;
            border-radius: 50%;
            background: linear-gradient(135deg, #F4A236, #E8952F);
            border: 3px solid #fff;
            box-shadow: 0 4px 15px rgba(244, 162, 54, 0.4);
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            font-size: 22px;
            transition: all 0.3s ease;
        }

        #cat-house-btn:hover {
            transform: scale(1.15);
            box-shadow: 0 6px 20px rgba(244, 162, 54, 0.6);
        }

        #cat-house-btn .tooltip {
            position: absolute;
            top: 55px;
            right: 0;
            transform: none;
            background: #333;
            color: white;
            padding: 4px 10px;
            border-radius: 8px;
            font-size: 11px;
            white-space: nowrap;
            opacity: 0;
            pointer-events: none;
            transition: opacity 0.2s;
        }

        #cat-house-btn:hover .tooltip {
            opacity: 1;
        }

        /* ===== Fancy Header Effects ===== */
        .kuma-title {
            font-size: 2.2rem;
            font-weight: 800;
            background: linear-gradient(90deg, #ff6b9d, #f4a236, #ff6b9d, #c084fc, #ff6b9d);
            background-size: 300% 100%;
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            animation: gradientShift 4s ease infinite, titleFloat 3s ease-in-out infinite;
            filter: drop-shadow(0 2px 8px rgba(255, 107, 157, 0.3));
            position: relative;
            display: inline-block;
        }

        .kuma-title:hover {
            animation: gradientShift 1s ease infinite, titleBounce 0.5s ease;
            filter: drop-shadow(0 4px 15px rgba(255, 107, 157, 0.5));
        }

        @keyframes gradientShift {
            0% {
                background-position: 0% 50%;
            }

            50% {
                background-position: 100% 50%;
            }

            100% {
                background-position: 0% 50%;
            }
        }

        @keyframes titleFloat {

            0%,
            100% {
                transform: translateY(0);
            }

            50% {
                transform: translateY(-4px);
            }
        }

        @keyframes titleBounce {

            0%,
            100% {
                transform: scale(1);
            }

            30% {
                transform: scale(1.05);
            }

            60% {
                transform: scale(0.97);
            }
        }

        .kuma-subtitle {
            font-size: 1rem;
            font-weight: 600;
            background: linear-gradient(90deg, #f4a236, #fcd34d, #f4a236);
            background-size: 200% 100%;
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            animation: shimmer 3s ease-in-out infinite;
            position: relative;
            display: inline-block;
            letter-spacing: 0.5px;
        }

        @keyframes shimmer {
            0% {
                background-position: -200% 0;
            }

            100% {
                background-position: 200% 0;
            }
        }

        /* Sparkle particles */
        .sparkle-container {
            position: relative;
            display: inline-block;
        }

        .sparkle {
            position: absolute;
            width: 6px;
            height: 6px;
            border-radius: 50%;
            background: #fcd34d;
            pointer-events: none;
            animation: sparkleAnim 2s ease-in-out infinite;
        }

        .sparkle:nth-child(1) {
            top: -8px;
            left: 10%;
            animation-delay: 0s;
            background: #ff6b9d;
        }

        .sparkle:nth-child(2) {
            top: -5px;
            right: 15%;
            animation-delay: 0.5s;
            background: #c084fc;
        }

        .sparkle:nth-child(3) {
            top: 0px;
            left: 50%;
            animation-delay: 1s;
            background: #fcd34d;
        }

        .sparkle:nth-child(4) {
            top: -10px;
            right: 30%;
            animation-delay: 1.5s;
            background: #f4a236;
        }

        @keyframes sparkleAnim {

            0%,
            100% {
                opacity: 0;
                transform: scale(0) translateY(0);
            }

            50% {
                opacity: 1;
                transform: scale(1) translateY(-10px);
            }
        }

        .cat-kaomoji {
            font-size: 2.8rem;
            display: inline-block;
            animation: kaomojiBounce 2s ease-in-out infinite;
            filter: drop-shadow(0 3px 6px rgba(253, 164, 175, 0.4));
        }

        @keyframes kaomojiBounce {

            0%,
            100% {
                transform: rotate(0deg) scale(1);
            }

            25% {
                transform: rotate(-5deg) scale(1.05);
            }

            75% {
                transform: rotate(5deg) scale(1.05);
            }
        }
    </style>
</head>

<body class="min-h-screen pb-20 overflow-x-hidden">
    <!-- AI Sidebar -->
    <div id="ai-sidebar"
        class="fixed left-0 top-0 h-full w-80 bg-white border-r-4 border-rose-200 shadow-2xl flex flex-col -translate-x-full">
        <!-- Toggle Button (Inside) -->
        <button onclick="toggleAI()"
            class="absolute -right-12 top-1/2 -translate-y-1/2 bg-white border-4 border-l-0 border-rose-200 p-2 rounded-r-2xl shadow-lg hover:bg-rose-50 transition-colors group">
            <span id="ai-toggle-icon" class="text-2xl block group-hover:scale-110 transition-transform">🐱</span>
        </button>

        <!-- Header -->
        <div class="p-6 border-b-2 border-rose-100 bg-rose-50/50">
            <h3 class="font-bold text-rose-500 flex items-center gap-2">
                <span class="text-2xl">🐱</span> ผู้ช่วย KUMA (คุมะ)
            </h3>
            <p class="text-xs text-rose-300 mt-1">สั่งให้คุมะสร้าง Test Case หรือถามอะไรก็ได้นะแง้ว!</p>
        </div>

        <!-- Chat Content -->
        <div id="chat-container" class="flex-1 overflow-y-auto p-4 space-y-4 bg-rose-50/20">
